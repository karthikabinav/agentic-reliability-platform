{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://agentic-reliability.dev/schemas/ark/trace.schema.v0.json",
  "title": "ARK Trace Row v0",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "ts",
    "suite",
    "model",
    "step_id",
    "tool_call",
    "event_type",
    "latency_ms",
    "error_type",
    "retry_count",
    "final_state"
  ],
  "properties": {
    "ts": {
      "type": "string",
      "format": "date-time"
    },
    "suite": {
      "type": "string",
      "minLength": 1
    },
    "model": {
      "type": "string",
      "minLength": 1
    },
    "step_id": {
      "type": "string",
      "minLength": 1
    },
    "tool_call": {
      "type": "string",
      "minLength": 1
    },
    "event_type": {
      "type": "string",
      "enum": [
        "task_completed",
        "task_failed"
      ]
    },
    "latency_ms": {
      "type": "integer",
      "minimum": 0
    },
    "error_type": {
      "type": [
        "string",
        "null"
      ]
    },
    "retry_count": {
      "type": "integer",
      "minimum": 0
    },
    "final_state": {
      "type": "string",
      "enum": [
        "pass",
        "fail"
      ]
    }
  }
}
